# Universal Database Connection URL
# Replace this string with the URL for your specific database engine.
# Format: dialect+driver://username:password@host:port/database

# Example for PostgreSQL:
# DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/DataWarehouse

# Example for Microsoft SQL Server (Windows Auth):
# DATABASE_URL=mssql+pyodbc://localhost/DataWarehouse?driver=ODBC+Driver+17+for+SQL+Server&Trusted_Connection=yes

# Example for MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost/DataWarehouse

DATABASE_URL=your_database_url_here
